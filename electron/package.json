{
  "name": "cortex-ide",
  "version": "0.1.0",
  "description": "Cortex IDE - AI-Powered Development Environment",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.cortex.ide",
    "productName": "Cortex IDE",
    "directories": {
      "output": "dist"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "icon.png"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "icon.icns"
    },
    "win": {
      "target": ["nsis"],
      "icon": "icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  }
}
